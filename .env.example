# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# Embedding backend: huggingface (local, free, no key) | nvidia | openai
EMBEDDING_PROVIDER=huggingface
# Model id for the active provider (a HuggingFace repo id by default)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Only needed if you switch EMBEDDING_PROVIDER to a paid/hosted backend later:
OPENAI_API_KEY=
NVIDIA_API_KEY=

# Qdrant location. ":memory:" = local in-memory store (Phase 1 default).
# For a running instance use e.g. http://localhost:6333
QDRANT_URL=:memory:

# Optional override (default in src/config/settings.py)
# QDRANT_COLLECTION=rag_portfolio
