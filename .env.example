# Copy to `.env` and fill in. `.env` is gitignored - never commit real secrets.

# Embedding backend: huggingface (local, free, no key) | nvidia | openai
EMBEDDING_PROVIDER=huggingface
# Model id for the active provider (a HuggingFace repo id by default)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# Local embedding device: auto (prefer MPS/CUDA) | mps | cuda | cpu
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=64

# LLM backend: ollama (local, free) | anthropic | openai
LLM_PROVIDER=ollama
# Model id for the active LLM provider (run `ollama pull <model>` first)
LLM_MODEL=qwen2.5:14b

# Only needed if you switch to a paid/hosted provider later:
OPENAI_API_KEY=
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=

# Qdrant location. ":memory:" = local in-memory store (Phase 1 default).
# For a running instance use e.g. http://localhost:6333
QDRANT_URL=:memory:

# Optional override (default in src/config/settings.py)
# QDRANT_COLLECTION=rag_portfolio
